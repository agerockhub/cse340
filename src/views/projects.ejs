<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <h2>Upcoming Service Projects</h2>
<p><a href="/new-project">Add a New Service Project</a></p>

        <ul>
            <% if (projects && projects.length> 0) { %>

                <% projects.forEach(project=> { %>

                    <% const formattedDate=project.date ? new Date(project.date).toLocaleDateString('en-US', {
                        year: 'numeric' , month: 'long' , day: 'numeric' }) : 'Date not available' ; %>

                        <li>
                            <!-- ✅ Project link -->
                            <a href="/project/<%= project.project_id %>">
                                <strong>
                                    <%= project.title %>
                                </strong>
                            </a>

                            <br>

                            <!-- Date -->
                            <span>
                                <%= formattedDate %>
                            </span>

                            <br>

                            <!-- ✅ Organization link -->
                            <span>
                                Organization:
                                <a href="/organization/<%= project.organization_id %>">
                                    <%= project.organization_name %>
                                </a>
                            </span>
                        </li>

                        <hr>

                        <% }) %>

                            <% } else { %>

                                <li>No projects available</li>

                                <% } %>
        </ul>

    </main>

    <%- include('partials/footer') %>