<%- include('partials/header') %>

    <main>
        <h1>Edit Project: <%= project.title %>
        </h1>

        <form action="/edit-project/<%= project.project_id %>" method="POST" class="form-container">
            <div class="form-group">
                <label for="title">Project Title</label>
                <input type="text" id="title" name="title" value="<%= project.title %>" required>
            </div>

            <div class="form-group">
                <label for="organizationId">Organization</label>
                <!-- ✅ Changed name to organizationId to match your controller -->
                <select name="organizationId" id="organizationId" required>
                    <% organizations.forEach(org=> { %>
                        <option value="<%= org.organization_id %>" <%=org.organization_id==project.organization_id
                            ? 'selected' : '' %>>
                            <%= org.name %>
                        </option>
                        <% }) %>
                </select>
            </div>

            <div class="form-group">
                <label for="location">Location</label>
                <input type="text" id="location" name="location" value="<%= project.location %>" required>
            </div>

            <div class="form-group">
                <label for="date">Date</label>
                <!-- ✅ Ensured split('T')[0] is used so the date displays in the picker -->
                <input type="date" id="date" name="date"
                    value="<%= new Date(project.date).toISOString().split('T')[0] %>" required>
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="5" required><%= project.description %></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary">Update Project</button>
                <a href="/project/<%= project.project_id %>" class="btn-cancel">Cancel</a>
            </div>
        </form>
    </main>

    <%- include('partials/footer') %>