<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <% if (projects && projects.length> 0) { %>
            <div class="project-list">
                <% projects.forEach(project=> { %>
                    <section class="project-item" style="border: 1px solid #ccc; padding: 1rem; margin-bottom: 1rem;">
                        <h3><a href="/project/<%= project.project_id %>">
                                <%= project.title %>
                            </a></h3>
                        <p><strong>Organization:</strong>
                            <%= project.organization_name %>
                        </p>
                        <p><strong>Date:</strong>
                            <%= new Date(project.project_date).toLocaleDateString() %>
                        </p>

                        <form action="/project/unvolunteer/<%= project.project_id %>" method="POST"
                            style="margin-top: 10px;">
                            <button type="submit" class="btn-danger"
                                onclick="return confirm('Are you sure you want to stop volunteering for this project?')">Remove</button>
                        </form>
                    </section>
                    <% }) %>
            </div>
            <% } else { %>
                <div class="empty-state">
                    <p>You haven't volunteered for any projects yet.</p>
                    <p><a href="/projects" class="btn-primary">Browse projects and sign up!</a></p>
                </div>
                <% } %>
    </main>

    <%- include('partials/footer') %>