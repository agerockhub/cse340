<%- include('partials/header') %>

    <main class="project-details">
        <h1>
            <%= project.title %>
        </h1>

        <div class="project-info">
            <p><strong>Organization:</strong>
                <%= project.organization_name %>
            </p>
            <p><strong>Location:</strong>
                <%= project.location %>
            </p>
            <p><strong>Date:</strong>
                <%= new Date(project.date).toLocaleDateString() %>
            </p>

            <div class="description">
                <h3>About this Project</h3>
                <p>
                    <%= project.description %>
                </p>
            </div>

            <% if (categories && categories.length> 0) { %>
                <div class="categories">
                    <h3>Categories</h3>
                    <ul>
                        <% categories.forEach(cat=> { %>
                            <li>
                                <%= cat.name %>
                            </li>
                            <% }) %>
                    </ul>
                </div>
                <% } %>

                    <hr>

                    <!-- VOLUNTEERING SECTION -->
                    <section class="volunteering-actions">
                        <% if (user) { %>
                            <% if (isVolunteering) { %>
                                <div class="volunteer-status">
                                    <p><strong>✅ You are volunteering for this project!</strong></p>
                                    <form action="/project/unvolunteer/<%= project.project_id %>" method="POST">
                                        <button type="submit" class="btn-secondary">Remove me as a volunteer</button>
                                    </form>
                                </div>
                                <% } else { %>
                                    <form action="/project/volunteer/<%= project.project_id %>" method="POST">
                                        <button type="submit" class="btn-primary">Volunteer for this project</button>
                                    </form>
                                    <% } %>
                                        <% } else { %>
                                            <p><a href="/login">Log in</a> to volunteer for this project.</p>
                                            <% } %>
                    </section>

                    <% if (user && user.role_name==='admin' ) { %>
                        <div class="admin-actions" style="margin-top: 20px;">
                            <a href="/edit-project/<%= project.project_id %>">Edit Project</a>
                        </div>
                        <% } %>
        </div>
    </main>

    <%- include('partials/footer') %>