<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <h2>Categories</h2>

        <ul>
            <% if (categories && categories.length> 0) { %>
                <% categories.forEach(category=> { %>
                    <li>
                        <!-- ✅ Link to category details -->
                        <a href="/category/<%= category.category_id %>">
                            <%= category.name %>
                        </a>
                    </li>
                    <% }) %>
                        <% } else { %>
                            <li>No categories available</li>
                            <% } %>
        </ul>
    </main>

    <%- include('partials/footer') %>