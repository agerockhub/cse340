<%- include('partials/header') %>

    <main class="form-view">
        <h1>
            <%= title %>
        </h1>

        <% if (errors) { %>
            <ul class="error-messages">
                <% errors.forEach(error=> { %>
                    <li>
                        <%= error.msg %>
                    </li>
                    <% }) %>
            </ul>
            <% } %>

                <form action="/edit-project/<%= project.project_id %>" method="POST" class="form-container">
                    <div class="form-group">
                        <label for="title">Project Title</label>
                        <input type="text" id="title" name="title" value="<%= project.title %>" required>
                    </div>

                    <div class="form-group">
                        <label for="organizationId">Organization</label>
                        <select name="organizationId" id="organizationId" required>
                            <option value="">Select an Organization</option>
                            <% organizations.forEach(org=> { %>
                                <option value="<%= org.organization_id %>"
                                    <%=(org.organization_id==project.organization_id) ? 'selected' : '' %>>
                                    <%= org.name %>
                                </option>
                                <% }) %>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="location">Location</label>
                        <input type="text" id="location" name="location" value="<%= project.location %>" required>
                    </div>

                    <div class="form-group">
                        <label for="date">Date</label>
                        <% // Format the date to YYYY-MM-DD for the HTML date picker const projectDate=new
                            Date(project.date).toISOString().split('T')[0]; %>
                            <input type="date" id="date" name="date" value="<%= projectDate %>" required>
                    </div>

                    <div class="form-group">
                        <label for="description">Description</label>
                        <textarea id="description" name="description" rows="5"
                            required><%= project.description %></textarea>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn-primary">Update Project</button>
                        <a href="/project/<%= project.project_id %>" class="btn-cancel">Cancel</a>
                    </div>
                </form>
    </main>

    <%- include('partials/footer') %>