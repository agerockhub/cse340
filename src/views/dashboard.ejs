<%- include('partials/header') %>

    <main class="container">
        <h1>User Dashboard</h1>

        <section class="welcome-message">
            <p>Welcome back, <strong>
                    <%= user.name %>
                </strong>!</p>
        </section>

        <section class="dashboard-actions" style="margin-top: 2rem;">
            <h2>My Activities</h2>
            <ul>
                <!-- THIS IS THE REQUIRED LINK -->
                <li><a href="/volunteering">View the projects I am volunteering for</a></li>
            </ul>

            <% if (user.role_name==='admin' ) { %>
                <hr>
                <h2>Administrative Tasks</h2>
                <ul>
                    <li><a href="/organizations/new">Add New Organization</a></li>
                    <li><a href="/new-project">Create New Service Project</a></li>
                    <li><a href="/users">Manage All Users</a></li>
                </ul>
                <% } %>
        </section>

        <p style="margin-top: 2rem;">
            <a href="/logout" class="btn-secondary">Log Out</a>
        </p>
    </main>

    <%- include('partials/footer') %>