<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>

        <form action="/new-project" method="POST">
            <div class="form-group">
                <label for="title">Project Title</label>
                <!-- ✅ Added value attribute to keep user input -->
                <input type="text" id="title" name="title" maxlength="150"
                    value="<%= locals.project ? project.title : '' %>" required />
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <!-- ✅ Added content between tags for textarea -->
                <textarea id="description" name="description" maxlength="500"
                    required><%= locals.project ? project.description : '' %></textarea>
            </div>

            <div class="form-group">
                <label for="location">Location</label>
                <input type="text" id="location" name="location" maxlength="255"
                    value="<%= locals.project ? project.location : '' %>" required />
            </div>

            <div class="form-group">
                <label for="date">Date</label>
                <input type="date" id="date" name="date" value="<%= locals.project ? project.date : '' %>" required />
            </div>

            <div class="form-group">
                <label for="organizationId">Organization</label>
                <select id="organizationId" name="organizationId" required>
                    <option value="">Select an organization</option>
                    <% organizations.forEach(org=> { %>
                        <option value="<%= org.organization_id %>" <%=(locals.project &&
                            project.organizationId==org.organization_id) ? 'selected' : '' %>>
                            <%= org.name %>
                        </option>
                        <% }); %>
                </select>
            </div>

            <button type="submit">Create Project</button>
        </form>
    </main>
    <%- include('partials/footer') %>